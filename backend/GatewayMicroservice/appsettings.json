{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ReverseProxy": {
        "Routes": {
            "aluno-route": {
                "ClusterId": "aluno-cluster",
                "Match": {
                    "Path": "/api/Aluno/{**catch-all}"
                }
            },
            "professor-route": {
                "ClusterId": "professor-cluster",
                "Match": {
                    "Path": "/api/Professor/{**catch-all}"
                }
            },
            "admin-route": {
                "ClusterId": "professor-cluster",
                "Match": {
                    "Path": "/api/Admin/{**catch-all}"
                }
            },
            "questao-route": {
                "ClusterId": "questao-cluster",
                "Match": {
                    "Path": "/api/Questao/{**catch-all}"
                }
            },
            "ia-route": {
                "ClusterId": "ia-cluster",
                "Match": {
                    "Path": "/api/ia/{**catch-all}"
                },
                "Transforms": [
                    {
                        "PathPattern": "{**catch-all}"
                    }
                ]
            },
            "dados-route": {
                "ClusterId": "dados-cluster",
                "Match": {
                    "Path": "/api/Dados/{**catch-all}"
                }
            },
            "turma-route": {
                "ClusterId": "turma-cluster",
                "Match": {
                    "Path": "/api/Turma/{**catch-all}"
                }
            },
            "lista-route": {
                "ClusterId": "lista-cluster",
                "Match": {
                    "Path": "/api/Lista/{**catch-all}"
                }
            }
        },
        "Clusters": {
            "aluno-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://aluno-api:8080"
                    }
                }
            },
            "professor-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://professor-api:8080"
                    }
                }
            },
            "questao-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://questao-api:8080"
                    }
                }
            },
            "ia-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://ia-service:8000"
                    }
                }
            },
            "dados-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://dados-api:8080"
                    }
                }
            },
            "turma-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://turma-api:8080"
                    }
                }
            },
            "lista-cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://lista-api:8080"
                    }
                }
            }
        }
    }
}