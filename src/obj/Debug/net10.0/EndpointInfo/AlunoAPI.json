{
  "openapi": "3.0.4",
  "info": {
    "title": "AlunoAPI",
    "description": "API responsável pelo gerenciamento de alunos da plataforma de questões.",
    "contact": {
      "name": "Luiz Fernando",
      "email": "luizfmd21@gmail.com"
    },
    "version": "v1"
  },
  "paths": {
    "/api/Aluno/criar-aluno": {
      "post": {
        "tags": [
          "Aluno"
        ],
        "summary": "Cadastra um novo aluno.",
        "requestBody": {
          "description": "Dados do aluno a ser cadastrado.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlunoRequestDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AlunoRequestDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AlunoRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "201": {
            "description": "Aluno cadastrado com sucesso."
          },
          "400": {
            "description": "Dados inválidos ou RA/Email já cadastrado."
          }
        }
      }
    },
    "/api/Aluno/alunos": {
      "get": {
        "tags": [
          "Aluno"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Aluno/{id}": {
      "get": {
        "tags": [
          "Aluno"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "Aluno"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlunoRequestDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AlunoRequestDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AlunoRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Aluno"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AlunoRequestDTO": {
        "required": [
          "email",
          "primeiroNome",
          "ra",
          "ultimoNome"
        ],
        "type": "object",
        "properties": {
          "primeiroNome": {
            "maxLength": 80,
            "minLength": 1,
            "type": "string"
          },
          "ultimoNome": {
            "maxLength": 80,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "ra": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Aluno"
    }
  ]
}